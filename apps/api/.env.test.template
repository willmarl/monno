PORT=3002
BASE_URL=http://localhost:3002
FRONTEND_URL=http://localhost:3000

# Test database — separate from dev DB
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/monno_test"

# Auth secrets (simple values fine for tests)
ACCESS_TOKEN_SECRET=test_access_secret
REFRESH_TOKEN_SECRET=test_refresh_secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Redis (used by BullMQ — tests degrade gracefully if not running)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_NAMESPACE=app_test

# High rate limits so tests never get throttled
THROTTLE_GLOBAL_LIMIT=10000
THROTTLE_GLOBAL_TTL=60000
THROTTLE_STRICT_LIMIT=10000
THROTTLE_NORMAL_LIMIT=10000
THROTTLE_LENIENT_LIMIT=10000
THROTTLE_VERY_LENIENT_LIMIT=10000

# Admin seed (not used in tests but required by the module)
SEED_ADMIN_USERNAME=admin_test
SEED_ADMIN_PASSWORD=admin_test

# Storage
STORAGE_BACKEND=local
LOCAL_UPLOAD_PATH=/tmp/monno_test_uploads

# Stub values for optional integrations (graceful if not set)
RESEND_API_KEY=re_test_stub
RESEND_FROM_EMAIL=noreply@test.local
RESEND_FROM_NAME=MonnoTest
POSTHOG_PROJECT_API_KEY=phc_test_stub
POSTHOG_HOST=https://us.i.posthog.com
GOOGLE_CLIENT_ID=test.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=test_secret
GOOGLE_REDIRECT_URL=http://localhost:3002/auth/google/callback
GITHUB_CLIENT_ID=test_github_id
GITHUB_CLIENT_SECRET=test_github_secret
GITHUB_REDIRECT_URL=http://localhost:3002/auth/github/callback
STRIPE_SECRET_KEY=sk_test_stub
STRIPE_PUBLISHABLE_KEY=pk_test_stub
STRIPE_WEBHOOK_SECRET=whsec_test_stub
SENTRY_DSN=
SENTRY_ENV=test
SENTRY_RELEASE=test
