################################################################################
#                            🔌 API (NestJS)                                  #
################################################################################

# Server Configuration
PORT=3001
BASE_URL=http://api.example.com
FRONTEND_URL=http://example.com

# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/appdb"

# Authentication Secrets (Development - Use simple secrets)
ACCESS_TOKEN_SECRET=supersecretaccessCHANGEME
REFRESH_TOKEN_SECRET=supersecretrefreshCHANGEME
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Redis Configuration (for caching and sessions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_NAMESPACE=app

################################################################################
#                      👤 ADMIN SEEDING                                       #
################################################################################

# Creates default admin account on startup (development only)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL= # optional
SEED_ADMIN_PASSWORD=admin

################################################################################
#                      📁 STORAGE (Local for Development)                     #
################################################################################

# Use local storage during development
STORAGE_BACKEND=local
LOCAL_UPLOAD_PATH=/home/johndoe/myrepos/monno/apps/api/uploads

# Oracle Object Storage Configuration (for reference)
S3_KEY=abc123
S3_SECRET=xxx
S3_BUCKET=bucket-12345678-1234
S3_REGION=us-ashburn-1
S3_ENDPOINT=https://xxxxx.compat.objectstorage.us-ashburn-1.oraclecloud.com
S3_PUBLIC_URL=https://xxxxx.compat.objectstorage.us-ashburn-1.oraclecloud.com/bucket-12345678-1234
S3_KEY_PREFIX=monno_uploads

################################################################################
#                      ⏱️  RATE LIMITING                                       #
################################################################################

# Global rate limiting (applies to all endpoints)
THROTTLE_GLOBAL_LIMIT=100 # 100 requests per 60 seconds globally
THROTTLE_GLOBAL_TTL=60000

# Rate limit tiers (requests per minute)
# Strict: Sensitive operations (payments, password changes, auth)
THROTTLE_STRICT_LIMIT=5 # recommend set to 5 but set to high for api testing

# Normal: Standard authenticated endpoints
THROTTLE_NORMAL_LIMIT=10 # recommend set to 10 but set to high for api testing

# Lenient: Read operations and user-generated content
THROTTLE_LENIENT_LIMIT=20 # recommend set to 20 but set to high for api testing

# Very Lenient: Frequent operations (likes, views)
THROTTLE_VERY_LENIENT_LIMIT=30 # recommend set to 30 but set to high for api testing

################################################################################
#                      ✉️  EMAIL (Resend)                                     #
################################################################################

RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@MyAppNameCHANGEME.app
RESEND_FROM_NAME=Monno

################################################################################
#                      📊 POSTHOG ANALYTICS                                   #
################################################################################

POSTHOG_PROJECT_API_KEY=phc_xxx
POSTHOG_HOST=https://us.i.posthog.com

################################################################################
#                      🔐 OAUTH (Google & GitHub)                             #
################################################################################

# Google OAuth (Development)
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REDIRECT_URL=http://api.example.com/auth/google/callback

# GitHub OAuth (Development)
GITHUB_CLIENT_ID=xxx
GITHUB_CLIENT_SECRET=xxx
GITHUB_REDIRECT_URL=http://api.example.com/auth/github/callback

################################################################################
#                      💳 STRIPE PAYMENT                                      #
################################################################################

STRIPE_SECRET_KEY=sk_xxx
STRIPE_PUBLISHABLE_KEY=pk_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

################################################################################
#                      🚨 ERROR TRACKING (Sentry)                             #
################################################################################

SENTRY_DSN=https://xxx.ingest.us.sentry.io/123
SENTRY_ENV=development
SENTRY_RELEASE=local
