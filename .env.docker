# Docker Compose environment variables
# Copy this to .env.docker.local to override defaults (git-ignored)
# Or set env vars before running: export DB_USER=custom_user && docker-compose up

# Database
DB_CONTAINER_NAME=monno_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=appdb
DB_PORT=5432

# Redis
REDIS_CONTAINER_NAME=monno_redis
REDIS_PORT=6379
